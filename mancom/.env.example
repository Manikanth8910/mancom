# =============================================================================
# MANCOM BACKEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env files to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# JWT Configuration (RS256)
# -----------------------------------------------------------------------------
# Path to RSA keys for JWT signing/verification
# Generate keys using: make generate-keys
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Token expiry times
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# JWT Issuer and Audience
JWT_ISSUER=mancom-auth
JWT_AUDIENCE=mancom-services

# -----------------------------------------------------------------------------
# Appwrite Configuration
# -----------------------------------------------------------------------------
# Your Appwrite instance endpoint
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Appwrite project ID
APPWRITE_PROJECT_ID=your-project-id

# Appwrite API key (with appropriate permissions)
APPWRITE_API_KEY=your-api-key

# -----------------------------------------------------------------------------
# Auth Service
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Visitor Service
# -----------------------------------------------------------------------------
VISITOR_SERVICE_PORT=3002
VISITOR_SERVICE_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mancom
DATABASE_USER=mancom
DATABASE_PASSWORD=mancom_dev_password
DATABASE_SSL=false

# Connection pool settings
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis (for refresh token storage)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
